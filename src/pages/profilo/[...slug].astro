---
import RootLayout from "../../layouts/RootLayout.astro";
import { ProfiloApp } from "../../components/profilo/ProfiloApp";
import { BookingDrawer } from "../../components/booking/BookingDrawer";
import { ToastViewport } from "../../components/ui/ToastViewport";

export function getStaticPaths() {
  return [
    { params: { slug: undefined } },
    { params: { slug: "appuntamenti" } },
    { params: { slug: "impostazioni" } },
    { params: { slug: "referral" } },
    { params: { slug: "storia" } },
    { params: { slug: "credito" } },
  ];
}
---

<RootLayout title="Profilo · Hair Rich Olbia" noindex={true}>
  <ProfiloApp client:only="react" />
  <BookingDrawer client:idle />
  <ToastViewport client:load />
</RootLayout>

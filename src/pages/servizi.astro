---
import RootLayout from "../layouts/RootLayout.astro";
import { SiteHeader } from "../components/ui/SiteHeader";
import { MobileTopBar } from "../components/ui/MobileTopBar";
import { BookingDrawer } from "../components/booking/BookingDrawer";
import { StickySlotPeek } from "../components/landing/StickySlotPeek";
import { ServicesHero } from "../components/landing/hero/ServicesHero";
import { StyleQuiz } from "../components/landing/StyleQuiz";
import { HomeServiceFocus } from "../components/landing/HomeServiceFocus";
import { ProcessSteps } from "../components/landing/_shared/ProcessSteps";
import { FAQAccordion } from "../components/landing/_shared/FAQAccordion";
import { Footer } from "../components/landing/Footer";
import { ToastViewport } from "../components/ui/ToastViewport";
import { MobileBottomBar } from "../components/ui/MobileBottomBar";
import { CartDrawer } from "../components/shop/CartDrawer";
import { ProductDrawer } from "../components/shop/ProductDrawer";

const PROCESS = [
  {
    n: "01",
    title: "Consulto · 2 minuti",
    body: "Prima delle forbici: forma del viso, stile di vita, tempo che puoi dedicare al mattino. Decidiamo insieme.",
  },
  {
    n: "02",
    title: "Esecuzione · forbice o rasoio",
    body: "Tecnica scelta sul risultato che vuoi, non sulla moda del mese. Lavaggio sempre incluso.",
  },
  {
    n: "03",
    title: "Finitura · prodotto giusto",
    body: "Styling con prodotto adatto al tuo capello, così a casa lo riproduci in 30 secondi.",
  },
];

const FAQ = [
  {
    q: "Posso prenotare il taglio a domicilio online?",
    a: "No: il taglio a domicilio è esclusivo e si organizza solo per telefono. Location, numero di teste, durata e tariffa li decidiamo insieme — chiama il numero del salone.",
  },
  {
    q: "Posso passare da solo capelli al combo durante l'appuntamento?",
    a: "Sì. Al consulto iniziale possiamo aggiungere la barba se la forma del viso lo chiede. Il prezzo viene ricalibrato in modo trasparente prima di iniziare.",
  },
  {
    q: "Servizi solo per uomo?",
    a: "Hair Rich è specializzato sull'uomo e sulla barba. Per styling unisex avanzato lavoriamo su prenotazione dedicata — scrivici e ti diciamo come gestiamo il caso.",
  },
];
---

<RootLayout
  title="Servizi e listino · Hair Rich Olbia"
  description="Taglio capelli 20€, taglio barba 10€, combo capelli + barba 30€. Listino trasparente, prenotazione online in 60 secondi. Taglio a domicilio solo telefonico."
  faqItems={FAQ.map((f) => ({ question: f.q, answer: f.a }))}
  breadcrumbs={[
    { name: "Home", url: "https://hair-rich.vercel.app/" },
    { name: "Servizi", url: "https://hair-rich.vercel.app/servizi/" },
  ]}
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <ServicesHero client:load />

    {/* Three bookable services — the only catalog block on the page */}
    <StyleQuiz client:load />

    {/* Phone-only home service: dedicated full-bleed focus block */}
    <HomeServiceFocus client:visible />

    {/* What happens during a service — short, no service repetition */}
    <ProcessSteps
      client:idle
      eyebrow="Il servizio Hair Rich"
      title="Cosa succede quando ti siedi."
      steps={PROCESS}
    />

    <FAQAccordion
      client:idle
      eyebrow="Domande sui servizi"
      title="Le più frequenti."
      items={FAQ}
    />

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
  <StickySlotPeek client:idle />
</RootLayout>

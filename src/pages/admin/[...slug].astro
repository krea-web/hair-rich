---
import RootLayout from "../../layouts/RootLayout.astro";
import { AdminApp } from "../../components/admin/AdminApp";

export function getStaticPaths() {
  const routes = [
    undefined,
    "agenda",
    "clienti",
    "ordini",
    "servizi",
    "prodotti",
    "staff",
    "impostazioni",
    "marketing",
    "gamification",
    "onboarding",
    "cms",
    "foto-risultati",
    "inbox",
    "waitlist",
    "clienti-no-show",
    "pacchetti",
    "funzionalita",
    "log",
    "chiusure",
    "orari",
    "statistiche",
    "agenda-week",
  ];
  return routes.map((slug) => ({ params: { slug } }));
}
---

<RootLayout title="Admin · Hair Rich Olbia" noindex={true}>
  <AdminApp client:only="react" />
</RootLayout>

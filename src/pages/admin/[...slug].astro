---
import RootLayout from "../../layouts/RootLayout.astro";
import { AdminApp } from "../../components/admin/AdminApp";
import { BookingDrawer } from "../../components/booking/BookingDrawer";
import { ToastViewport } from "../../components/ui/ToastViewport";

export function getStaticPaths() {
  const routes = [
    undefined,
    "agenda",
    "clienti",
    "ordini",
    "servizi",
    "prodotti",
    "staff",
    "impostazioni",
    "marketing",
    "gamification",
    "onboarding",
    "cms",
    "foto-risultati",
    "inbox",
    "waitlist",
    "clienti-no-show",
    "pacchetti",
    "sondaggi",
    "clienti-cerca",
    "contenuti-ai",
    "fornitori",
    "spese",
    "qr-promo",
    "funzionalita",
    "log",
    "chiusure",
    "orari",
    "statistiche",
    "agenda-week",
    "salute",
    "hardware",
  ];
  return routes.map((slug) => ({ params: { slug } }));
}
---

<RootLayout title="Admin · Hair Rich Olbia" noindex={true}>
  <AdminApp client:only="react" />
  <BookingDrawer client:idle />
  <ToastViewport client:idle />
</RootLayout>

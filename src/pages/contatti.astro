---
import RootLayout from "../layouts/RootLayout.astro";
import { SiteHeader } from "../components/ui/SiteHeader";
import { MobileTopBar } from "../components/ui/MobileTopBar";
import { BookingDrawer } from "../components/booking/BookingDrawer";
import { StickySlotPeek } from "../components/landing/StickySlotPeek";
import { PageHero } from "../components/landing/_shared/PageHero";
import { ContactForm } from "../components/landing/ContactForm";
import { GettingHere } from "../components/landing/GettingHere";
import { MapSection } from "../components/landing/MapSection";
import { Footer } from "../components/landing/Footer";
import { ToastViewport } from "../components/ui/ToastViewport";
import { MobileBottomBar } from "../components/ui/MobileBottomBar";
import { CartDrawer } from "../components/shop/CartDrawer";
import { ProductDrawer } from "../components/shop/ProductDrawer";
import { BookingCTA } from "../components/landing/_shared/BookingCTA";

import { SITE } from "../lib/constants";

const phoneHref = "tel:" + SITE.phone.replace(/\s+/g, "");
const mailHref = "mailto:" + SITE.email;
const mapsHref =
  "https://www.google.com/maps/dir/?api=1&destination=" + encodeURIComponent(SITE.address);
---

<RootLayout
  title="Contatti · Hair Rich Olbia"
  description="Telefono, WhatsApp, email e indirizzo di Hair Rich Olbia. Per prenotare un taglio usa il booking online; questo form è dedicato a collaborazioni, stampa e proposte fornitori."
  breadcrumbs={[
    { name: "Home", url: "https://hair-rich.vercel.app/" },
    { name: "Contatti", url: "https://hair-rich.vercel.app/contatti/" },
  ]}
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <PageHero
      client:load
      eyebrow="Contatti · Salone"
      titleA="Parliamoci"
      titleB="direttamente"
      intro="Telefono o email — risposta entro un'ora lavorativa. Oppure passa direttamente da noi in Via Regina Elena 33/A."
      bgImage="salone-vetrina.webp"
      bgImageBucket="asset"
      metaLeft="Risposta · 1h lavorativa"
      metaRight="05 / Contatti"
    />

    {/* Quick action chips — mobile-first, native tap to call/email/Maps */}
    <section class="relative px-4 md:px-12 lg:px-20 -mt-8 md:-mt-12 z-20" aria-label="Azioni rapide">
      <div class="max-w-5xl mx-auto grid grid-cols-3 gap-2 md:gap-4">
        <a
          href={phoneHref}
          class="group flex flex-col items-center gap-1.5 py-4 md:py-5 px-3 bg-carbon border border-line rounded-[var(--radius-md)] hover:border-accent-warm/40 transition-colors active:scale-95"
        >
          <svg viewBox="0 0 24 24" class="w-5 h-5 md:w-6 md:h-6 text-accent-warm" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.91.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0122 16.92z" />
          </svg>
          <span class="text-[10px] uppercase tracking-[0.25em] text-silver-dark group-hover:text-warm-white font-body font-semibold transition-colors">
            Chiama
          </span>
        </a>
        <a
          href={mailHref}
          class="group flex flex-col items-center gap-1.5 py-4 md:py-5 px-3 bg-carbon border border-line rounded-[var(--radius-md)] hover:border-accent-warm/40 transition-colors active:scale-95"
        >
          <svg viewBox="0 0 24 24" class="w-5 h-5 md:w-6 md:h-6 text-accent-warm" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6" />
          </svg>
          <span class="text-[10px] uppercase tracking-[0.25em] text-silver-dark group-hover:text-warm-white font-body font-semibold transition-colors">
            Email
          </span>
        </a>
        <a
          href={mapsHref}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center gap-1.5 py-4 md:py-5 px-3 bg-carbon border border-line rounded-[var(--radius-md)] hover:border-accent-warm/40 transition-colors active:scale-95"
        >
          <svg viewBox="0 0 24 24" class="w-5 h-5 md:w-6 md:h-6 text-accent-warm" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span class="text-[10px] uppercase tracking-[0.25em] text-silver-dark group-hover:text-warm-white font-body font-semibold transition-colors">
            Indicazioni
          </span>
        </a>
      </div>
    </section>

    {/* Booking CTA — most visitors to /contatti want a haircut, not a form */}
    <section class="relative py-14 md:py-20 px-6 md:px-12 lg:px-20 bg-black">
      <div class="max-w-3xl mx-auto text-center space-y-5">
        <span class="text-[10px] uppercase tracking-[0.4em] text-accent-warm font-body font-semibold">
          Vuoi prenotare?
        </span>
        <h2 class="text-display text-3xl md:text-5xl text-warm-white tracking-tight leading-[0.95]">
          Il booking è il modo più rapido.
        </h2>
        <p class="text-warm-white-muted text-base md:text-lg max-w-xl mx-auto leading-relaxed">
          Scegli servizio, barber e orario in 60 secondi. Conferma immediata, zero
          telefonate. Se preferisci comunque sentirci, i recapiti qui sopra sono attivi
          negli orari di apertura.
        </p>
        <div class="pt-2">
          <BookingCTA client:load source="contatti-hero" />
        </div>
      </div>
    </section>

    {/* Recapiti dettagliati */}
    <section class="relative py-12 md:py-20 px-6 md:px-12 lg:px-20 bg-carbon/40 border-y border-line">
      <div class="max-w-5xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
          <span class="text-[10px] uppercase tracking-[0.4em] text-accent-warm font-body font-semibold">
            Recapiti
          </span>
          <h2 class="text-display text-3xl md:text-4xl text-warm-white tracking-tight mt-3">
            Come raggiungerci.
          </h2>
        </div>

        <ul class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-5">
          <li class="bg-black border border-line rounded-[var(--radius-md)] p-6 md:p-7 hover:border-accent-warm/40 transition-colors">
            <div class="w-11 h-11 rounded-full border border-accent-warm/40 bg-accent-warm/5 flex items-center justify-center text-accent-warm mb-4">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.91.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0122 16.92z" />
              </svg>
            </div>
            <span class="text-[10px] uppercase tracking-[0.3em] text-silver-dark font-body font-semibold">
              Telefono
            </span>
            <a href={phoneHref} class="block text-warm-white text-lg md:text-xl font-display mt-1 hover:text-accent-warm transition-colors">
              {SITE.phone}
            </a>
            <p class="mt-2 text-silver-dark text-xs leading-relaxed">
              Disponibili negli orari di apertura.
            </p>
          </li>

          <li class="bg-black border border-line rounded-[var(--radius-md)] p-6 md:p-7 hover:border-accent-warm/40 transition-colors">
            <div class="w-11 h-11 rounded-full border border-accent-warm/40 bg-accent-warm/5 flex items-center justify-center text-accent-warm mb-4">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6" />
              </svg>
            </div>
            <span class="text-[10px] uppercase tracking-[0.3em] text-silver-dark font-body font-semibold">
              Email
            </span>
            <a href={mailHref} class="block text-warm-white text-lg md:text-xl font-display mt-1 hover:text-accent-warm transition-colors break-all">
              {SITE.email}
            </a>
            <p class="mt-2 text-silver-dark text-xs leading-relaxed">
              Risposta entro un'ora lavorativa.
            </p>
          </li>

          <li class="bg-black border border-line rounded-[var(--radius-md)] p-6 md:p-7 hover:border-accent-warm/40 transition-colors">
            <div class="w-11 h-11 rounded-full border border-accent-warm/40 bg-accent-warm/5 flex items-center justify-center text-accent-warm mb-4">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <span class="text-[10px] uppercase tracking-[0.3em] text-silver-dark font-body font-semibold">
              Salone
            </span>
            <p class="text-warm-white text-lg md:text-xl font-display mt-1 leading-tight">
              Via Regina Elena 33/A<br/>Olbia (SS)
            </p>
            <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="mt-2 inline-flex items-center gap-1.5 text-[10px] uppercase tracking-[0.3em] text-accent-warm font-body font-semibold hover:text-warm-white transition-colors">
              Apri in Maps
              <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <GettingHere client:idle />

    <MapSection client:idle />

    {/* Form: SOLO non-booking (collaborazioni / stampa / fornitori / altro) */}
    <section class="relative py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-black">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8 md:mb-10">
          <span class="text-[10px] uppercase tracking-[0.4em] text-accent-warm font-body font-semibold">
            Lavorare con noi
          </span>
          <h2 class="text-display text-3xl md:text-4xl text-warm-white tracking-tight mt-3">
            Collaborazioni, stampa, proposte.
          </h2>
          <p class="mt-3 text-warm-white-muted text-base md:text-lg leading-relaxed max-w-2xl">
            Questo form è dedicato a partnership, redazioni, brand e fornitori.
            <strong class="text-warm-white"> Per prenotare un taglio</strong>,
            usa il booking dal bottone qui sopra o
            <a href={phoneHref} class="underline text-accent-warm hover:text-warm-white transition-colors"> chiamaci</a>.
          </p>
        </div>
        <ContactForm client:load />
      </div>
    </section>

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
  <StickySlotPeek client:idle />
</RootLayout>

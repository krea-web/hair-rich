---
import RootLayout from "../layouts/RootLayout.astro";
import { SiteHeader } from "../components/ui/SiteHeader";
import { MobileTopBar } from "../components/ui/MobileTopBar";
import { BookingDrawer } from "../components/booking/BookingDrawer";
import { StickySlotPeek } from "../components/landing/StickySlotPeek";
import { PortfolioHero } from "../components/landing/hero/PortfolioHero";
import { PortfolioGallery } from "../components/landing/PortfolioGallery";
import { BeforeAfterSlider } from "../components/landing/BeforeAfterSlider";
import { FeaturedWork } from "../components/landing/FeaturedWork";
import { Footer } from "../components/landing/Footer";
import { ToastViewport } from "../components/ui/ToastViewport";
import { MobileBottomBar } from "../components/ui/MobileBottomBar";
import { CartDrawer } from "../components/shop/CartDrawer";
import { ProductDrawer } from "../components/shop/ProductDrawer";
---

<RootLayout
  title="Portfolio · Hair Rich Olbia"
  description="Galleria completa di tagli, fade, barbe e styling realizzati da Hair Rich Olbia. Trasformazioni prima/dopo, filtri per categoria, archive editorial."
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <PortfolioHero client:load />

    <BeforeAfterSlider client:visible />

    <PortfolioGallery client:visible />

    <FeaturedWork
      client:visible
      image="provvisorio/IMG_2493.jpeg"
      badge="Lavoro del mese"
      subtitle="Maggio 2026"
      title="Razor cut con fade graduato"
      body="Cliente abituale, vista due settimane prima per definire una direzione: meno volume sui lati, più texture sulla sommità. Lavorato a rasoio sulle punte per ammorbidire la caduta naturale, fade alla nuca per pulizia. Risultato: pettinabile in 30 secondi al mattino senza prodotto."
      meta={[
        { label: "Master barber", value: "Federico Asara" },
        { label: "Tempo", value: "55 minuti" },
        { label: "Tecnica", value: "Razor + Fade" },
        { label: "Manutenzione", value: "Ogni 3 settimane" },
      ]}
    />

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
  <StickySlotPeek client:idle />
</RootLayout>

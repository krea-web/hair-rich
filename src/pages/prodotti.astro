---
import RootLayout from "../layouts/RootLayout.astro";
import { SiteHeader } from "../components/ui/SiteHeader";
import { MobileTopBar } from "../components/ui/MobileTopBar";
import { BookingDrawer } from "../components/booking/BookingDrawer";
import { StickySlotPeek } from "../components/landing/StickySlotPeek";
import { ShopHero } from "../components/landing/hero/ShopHero";
import { ProductCatalog } from "../components/landing/ProductCatalog";
import { MerchCTA } from "../components/shop/MerchCTA";
import { FAQAccordion } from "../components/landing/_shared/FAQAccordion";
import { Footer } from "../components/landing/Footer";
import { ToastViewport } from "../components/ui/ToastViewport";
import { MobileBottomBar } from "../components/ui/MobileBottomBar";
import { CartDrawer } from "../components/shop/CartDrawer";
import { ProductDrawer } from "../components/shop/ProductDrawer";

const FAQ = [
  {
    q: "Posso pagare online?",
    a: "No, per scelta. Si prenotano i prodotti online e si pagano in salone al ritiro — contanti, bancomat o carte. È il modo in cui ci piace gestire un piccolo retail: senza intermediari di pagamento e con un saluto in più al cliente.",
  },
  {
    q: "Quanto tempo ho per ritirare?",
    a: "Sette giorni dall'ordine. Riceverai un codice corto (es. \"7HZ3K9\") che mostri al barber e in due secondi prendiamo i prodotti dal magazzino. Se non puoi entro la settimana scrivici, lo teniamo in caldo.",
  },
  {
    q: "Posso provare un prodotto prima di acquistarlo?",
    a: "Sì, in salone abbiamo i tester aperti per pomate, cere e oli. Passa, ti facciamo provare la texture in mano. Non vendiamo niente al buio.",
  },
  {
    q: "Cosa succede se un prodotto non mi convince?",
    a: "Hai 14 giorni per cambiarlo o ottenere un buono di pari valore. Lo sostituiamo direttamente in salone — nessun reso da spedire.",
  },
];
---

<RootLayout
  title="Prodotti · Hair Rich Olbia"
  description="Pomate, cere, oli barba, strumenti e accessori selezionati da Hair Rich Olbia. Prenoti online, paghi e ritiri in salone."
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <ShopHero client:load />

    <ProductCatalog client:visible />

    <FAQAccordion
      client:idle
      eyebrow="Come funziona"
      title="Pagamento e ritiro, semplice."
      items={FAQ}
    />

    <MerchCTA client:visible />

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <StickySlotPeek client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
</RootLayout>

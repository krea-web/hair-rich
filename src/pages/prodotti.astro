---
import RootLayout from "../layouts/RootLayout.astro";
import { SiteHeader } from "../components/ui/SiteHeader";
import { MobileTopBar } from "../components/ui/MobileTopBar";
import { BookingDrawer } from "../components/booking/BookingDrawer";
import { StickySlotPeek } from "../components/landing/StickySlotPeek";
import { ShopHero } from "../components/landing/hero/ShopHero";
import { ProductCatalog } from "../components/landing/ProductCatalog";
import { MerchCTA } from "../components/shop/MerchCTA";
import { ProductsFaq } from "../components/landing/_shared/ProductsFaq";
import { Footer } from "../components/landing/Footer";
import { ToastViewport } from "../components/ui/ToastViewport";
import { MobileBottomBar } from "../components/ui/MobileBottomBar";
import { CartDrawer } from "../components/shop/CartDrawer";
import { ProductDrawer } from "../components/shop/ProductDrawer";
import { useTranslations, getLangFromUrl, localizePath, type Locale } from "@/i18n";
import { SITE } from "../lib/constants";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = SITE.url;

const META: Record<Locale, { title: string; description: string }> = {
  it: { title: "Prodotti · Hair Rich Olbia", description: "Pomate, cere, oli barba, strumenti e accessori selezionati da Hair Rich Olbia. Prenoti online, paghi e ritiri in salone." },
  en: { title: "Products · Hair Rich Olbia", description: "Pomades, waxes, beard oils, tools and accessories selected by Hair Rich Olbia. Reserve online, pay and pick up at the salon." },
  fr: { title: "Produits · Hair Rich Olbia", description: "Pommades, cires, huiles à barbe, outils et accessoires sélectionnés par Hair Rich Olbia. Réservez en ligne, payez et retirez au salon." },
  de: { title: "Produkte · Hair Rich Olbia", description: "Pomaden, Wachse, Bartöle, Werkzeuge und Zubehör, ausgewählt von Hair Rich Olbia. Online reservieren, im Salon zahlen und abholen." },
};
const m = META[lang];

const domicilioHref = lang === "it" ? "/taglio-a-domicilio" : `/${lang}/taglio-a-domicilio`;
const domNote: Record<Locale, { text: string; link: string }> = {
  it: { text: "Gli stessi prodotti professionali li usiamo anche per il", link: "taglio a domicilio in Costa Smeralda" },
  en: { text: "We use the same professional products for our", link: "mobile barber service in the Costa Smeralda" },
  fr: { text: "Nous utilisons les mêmes produits professionnels pour le", link: "barbier à domicile en Costa Smeralda" },
  de: { text: "Dieselben professionellen Produkte verwenden wir auch für den", link: "mobilen Barbier an der Costa Smeralda" },
};
const dn = domNote[lang];
---

<RootLayout
  title={m.title}
  description={m.description}
  breadcrumbs={[
    { name: t.nav.home, url: base + localizePath("/", lang) },
    { name: t.nav.products, url: base + localizePath("/prodotti", lang) },
  ]}
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <ShopHero client:load />

    <ProductCatalog client:visible />

    <ProductsFaq client:idle />

    <MerchCTA client:visible />

    <section class="bg-black border-t border-line">
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-10 md:py-12 text-center">
        <p class="text-warm-white-muted font-body text-sm md:text-base">
          {dn.text}{" "}
          <a
            href={domicilioHref}
            class="text-accent-warm underline decoration-accent-warm/40 underline-offset-4 hover:decoration-accent-warm transition"
          >{dn.link}</a>.
        </p>
      </div>
    </section>

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <StickySlotPeek client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
</RootLayout>

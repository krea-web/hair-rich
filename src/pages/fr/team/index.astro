---
import RootLayout from "../../../layouts/RootLayout.astro";
import { SiteHeader } from "../../../components/ui/SiteHeader";
import { MobileTopBar } from "../../../components/ui/MobileTopBar";
import { BookingDrawer } from "../../../components/booking/BookingDrawer";
import { StickySlotPeek } from "../../../components/landing/StickySlotPeek";
import { TeamHero } from "../../../components/landing/hero/TeamHero";
import { TeamShowcase } from "../../../components/landing/TeamShowcase";
import { SalonDay } from "../../../components/landing/SalonDay";
import { TeamValues } from "../../../components/landing/_shared/TeamValues";
import { InstagramSection } from "../../../components/landing/InstagramSection";
import { Footer } from "../../../components/landing/Footer";
import { ToastViewport } from "../../../components/ui/ToastViewport";
import { MobileBottomBar } from "../../../components/ui/MobileBottomBar";
import { CartDrawer } from "../../../components/shop/CartDrawer";
import { ProductDrawer } from "../../../components/shop/ProductDrawer";
import { assetImageUrl } from "../../../lib/supabase/queries";
import { useTranslations, getLangFromUrl, localizePath, type Locale } from "@/i18n";
import { SITE } from "../../../lib/constants";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = SITE.url;
const SITE_URL = SITE.url;

const META: Record<Locale, { title: string; description: string }> = {
  it: { title: "Il team · Hair Rich Olbia", description: "Federico Asara, Cristian e tutto il team di Hair Rich Olbia. Master barber e senior barber sardi, formazione continua, mani sul lavoro dal 2017." },
  en: { title: "The team · Hair Rich Olbia", description: "Federico Asara, Cristian and the whole Hair Rich Olbia team. Sardinian master and senior barbers, continuous training, hands on the work since 2017." },
  fr: { title: "L'équipe · Hair Rich Olbia", description: "Federico Asara, Cristian et toute l'équipe de Hair Rich Olbia. Master et senior barbers sardes, formation continue, à l'œuvre depuis 2017." },
  de: { title: "Das Team · Hair Rich Olbia", description: "Federico Asara, Cristian und das ganze Hair Rich Olbia Team. Sardische Master- und Senior-Barbiere, kontinuierliche Ausbildung, am Werk seit 2017." },
};
const m = META[lang];

// Person schema (E-E-A-T) per i barber del team — fetch a build time.
let teamPersons: Array<Record<string, unknown>> = [];
try {
  const sbUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const sbKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (sbUrl && sbKey) {
    const res = await fetch(
      `${sbUrl}/rest/v1/staff?select=*&is_active=eq.true&show_on_team_page=eq.true&order=sort_order.asc`,
      { headers: { apikey: sbKey, Authorization: `Bearer ${sbKey}` } }
    );
    if (res.ok) {
      const rows = await res.json();
      teamPersons = rows
        .filter((s: any) => s.role_type !== "founder" || s.full_bio || s.bio)
        .map((s: any) => {
          const photoRaw = s.avatar_url ?? s.cover_url ?? "";
          const image = photoRaw
            ? photoRaw.startsWith("http")
              ? photoRaw
              : assetImageUrl(photoRaw, { width: 800, quality: 82, format: "webp" })
            : undefined;
          return {
            name: s.name,
            jobTitle: s.role || "Barber",
            description:
              s.tagline || (s.full_bio ?? s.bio ?? "").slice(0, 220).replace(/\s+\S*$/, ""),
            image,
            url: `${SITE_URL}/team/${s.slug}/`,
            knowsAbout:
              Array.isArray(s.expertise) && s.expertise.length > 0 ? s.expertise : undefined,
          };
        });
    }
  }
} catch {
  teamPersons = [];
}
---

<RootLayout
  title={m.title}
  description={m.description}
  breadcrumbs={[
    { name: t.nav.home, url: base + localizePath("/", lang) },
    { name: t.nav.team, url: base + localizePath("/team", lang) },
  ]}
  persons={teamPersons}
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <TeamHero client:load />

    <TeamShowcase client:idle />

    <SalonDay client:idle />

    <TeamValues client:idle />

    <InstagramSection client:visible />

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
  <StickySlotPeek client:idle />
</RootLayout>

---
import RootLayout from "../../layouts/RootLayout.astro";
import { SiteHeader } from "../../components/ui/SiteHeader";
import { MobileTopBar } from "../../components/ui/MobileTopBar";
import { BookingDrawer } from "../../components/booking/BookingDrawer";
import { StickySlotPeek } from "../../components/landing/StickySlotPeek";
import { ServicesHero } from "../../components/landing/hero/ServicesHero";
import { StyleQuiz } from "../../components/landing/StyleQuiz";
import { HomeServiceFocus } from "../../components/landing/HomeServiceFocus";
import { ServicesProcess } from "../../components/landing/_shared/ServicesProcess";
import { ServicesFaq } from "../../components/landing/_shared/ServicesFaq";
import { Footer } from "../../components/landing/Footer";
import { ToastViewport } from "../../components/ui/ToastViewport";
import { MobileBottomBar } from "../../components/ui/MobileBottomBar";
import { CartDrawer } from "../../components/shop/CartDrawer";
import { ProductDrawer } from "../../components/shop/ProductDrawer";
import { useTranslations, getLangFromUrl, localizePath, type Locale } from "@/i18n";
import { SITE } from "../../lib/constants";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = SITE.url;

const META: Record<Locale, { title: string; description: string }> = {
  it: {
    title: "Servizi e listino · Hair Rich Olbia",
    description: "Taglio capelli 20€, taglio barba 10€, combo capelli + barba 30€. Listino trasparente, prenotazione online in 60 secondi. Taglio a domicilio solo telefonico.",
  },
  en: {
    title: "Services & prices · Hair Rich Olbia",
    description: "Haircut €20, beard €10, cut + beard combo €30. Transparent price list, book online in 60 seconds. Home haircuts by phone only.",
  },
  fr: {
    title: "Services & tarifs · Hair Rich Olbia",
    description: "Coupe 20€, barbe 10€, combo coupe + barbe 30€. Tarifs transparents, réservation en ligne en 60 secondes. Coupe à domicile par téléphone uniquement.",
  },
  de: {
    title: "Services & Preise · Hair Rich Olbia",
    description: "Haarschnitt 20€, Bart 10€, Combo Schnitt + Bart 30€. Transparente Preisliste, Online-Buchung in 60 Sekunden. Hausbesuch-Schnitt nur telefonisch.",
  },
};
const m = META[lang];
const faqItems = t.servicesPage.faq.map((f) => ({ question: f.q, answer: f.a }));
---

<RootLayout
  title={m.title}
  description={m.description}
  faqItems={faqItems}
  breadcrumbs={[
    { name: t.nav.home, url: base + localizePath("/", lang) },
    { name: t.nav.services, url: base + localizePath("/servizi", lang) + "/" },
  ]}
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <ServicesHero client:load />
    <StyleQuiz client:load />
    <HomeServiceFocus client:visible />
    <ServicesProcess client:idle />
    <ServicesFaq client:idle />
    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
  <StickySlotPeek client:idle />
</RootLayout>

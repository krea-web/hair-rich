---
import RootLayout from "../../layouts/RootLayout.astro";
import { SiteHeader } from "../../components/ui/SiteHeader";
import { MobileTopBar } from "../../components/ui/MobileTopBar";
import { BookingDrawer } from "../../components/booking/BookingDrawer";
import { StickySlotPeek } from "../../components/landing/StickySlotPeek";
import { PortfolioHero } from "../../components/landing/hero/PortfolioHero";
import { PortfolioGallery } from "../../components/landing/PortfolioGallery";
import { BeforeAfterSlider } from "../../components/landing/BeforeAfterSlider";
import { FeaturedWork } from "../../components/landing/FeaturedWork";
import { Footer } from "../../components/landing/Footer";
import { ToastViewport } from "../../components/ui/ToastViewport";
import { MobileBottomBar } from "../../components/ui/MobileBottomBar";
import { CartDrawer } from "../../components/shop/CartDrawer";
import { ProductDrawer } from "../../components/shop/ProductDrawer";
import { useTranslations, getLangFromUrl, localizePath, type Locale } from "@/i18n";
import { SITE } from "../../lib/constants";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = SITE.url;
const lp = t.lavoriPage;

const META: Record<Locale, { title: string; description: string }> = {
  it: { title: "Portfolio · Hair Rich Olbia", description: "Galleria completa di tagli, fade, barbe e styling realizzati da Hair Rich Olbia. Trasformazioni prima/dopo, filtri per categoria, archive editorial." },
  en: { title: "Portfolio · Hair Rich Olbia", description: "Full gallery of cuts, fades, beards and styling by Hair Rich Olbia. Before/after transformations, category filters, editorial archive." },
  fr: { title: "Portfolio · Hair Rich Olbia", description: "Galerie complète de coupes, fades, barbes et coiffage par Hair Rich Olbia. Transformations avant/après, filtres par catégorie, archive éditoriale." },
  de: { title: "Portfolio · Hair Rich Olbia", description: "Vollständige Galerie von Schnitten, Fades, Bärten und Styling von Hair Rich Olbia. Vorher/Nachher-Transformationen, Kategorienfilter, redaktionelles Archiv." },
};
const m = META[lang];
---

<RootLayout
  title={m.title}
  description={m.description}
  breadcrumbs={[
    { name: t.nav.home, url: base + localizePath("/", lang) },
    { name: t.nav.gallery, url: base + localizePath("/lavori", lang) },
  ]}
>
  <SiteHeader client:load />
  <MobileTopBar client:load />
  <main>
    <PortfolioHero client:load />
    <BeforeAfterSlider client:visible />
    <PortfolioGallery client:visible />
    <FeaturedWork
      client:visible
      image="tagli/taper-fade-01.jpeg"
      badge={lp.featuredBadge}
      subtitle={lp.featuredSubtitle}
      title={lp.featuredTitle}
      body={lp.featuredBody}
      meta={lp.featuredMeta}
    />
    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <BookingDrawer client:idle />
  <CartDrawer client:idle />
  <ProductDrawer client:idle />
  <StickySlotPeek client:idle />
</RootLayout>

---
import RootLayout from "../layouts/RootLayout.astro";
import { SiteHeader } from "../components/ui/SiteHeader";
import { MobileMenu } from "../components/ui/MobileMenu";
import { BookingDrawer } from "../components/booking/BookingDrawer";
import { PageHero } from "../components/landing/_shared/PageHero";
import { BookingSection } from "../components/landing/BookingSection";
import { ProcessSteps } from "../components/landing/_shared/ProcessSteps";
import { FAQAccordion } from "../components/landing/_shared/FAQAccordion";
import { Footer } from "../components/landing/Footer";
import { ToastViewport } from "../components/ui/ToastViewport";
import { MobileBottomBar } from "../components/ui/MobileBottomBar";

const STEPS = [
  {
    n: "01",
    title: "Scegli il servizio",
    body: "Taglio, barba, combo o rituale completo. Ogni opzione ha tempo e prezzo trasparenti — niente sorprese.",
  },
  {
    n: "02",
    title: "Scegli data e ora",
    body: "Lo slot mostrato è davvero libero in quel momento — niente over-booking, niente telefonate per spostarti.",
  },
  {
    n: "03",
    title: "Conferma in 30 secondi",
    body: "Nome, telefono ed email. Nessun pagamento richiesto online: si salda in salone post-servizio.",
  },
];

const POLICIES = [
  {
    n: "01",
    title: "Cancellazione gratuita",
    body: "Fino a 2 ore prima dell'appuntamento, senza alcun costo. Sotto le 2 ore ti chiediamo di telefonarci direttamente.",
  },
  {
    n: "02",
    title: "Pagamento in salone",
    body: "Nessuna carta richiesta per prenotare. Si salda al termine del servizio: contanti, bancomat, Visa, Mastercard, Maestro, Amex.",
  },
  {
    n: "03",
    title: "Promemoria automatico",
    body: "Ricevi un'email di conferma immediata e un promemoria 24 ore prima dell'appuntamento — così non te lo dimentichi.",
  },
];

const FAQ = [
  {
    q: "Devo creare un account per prenotare?",
    a: "No. Puoi prenotare come ospite lasciando nome e telefono. L'account serve solo se vuoi gestire più prenotazioni nel tempo o accedere a vantaggi del passaparola.",
  },
  {
    q: "Posso annullare o spostare un appuntamento?",
    a: "Sì. Fino a 2 ore prima dell'orario fissato, gratuitamente, scrivendo al numero del salone o (se hai un account) dal tuo profilo. Sotto le 2 ore ti chiediamo cortesemente di telefonare.",
  },
  {
    q: "Quali metodi di pagamento accettate?",
    a: "Contanti, bancomat e tutte le carte di credito/debito principali (Visa, Mastercard, Maestro, American Express). Il pagamento avviene in salone, mai online.",
  },
  {
    q: "Cosa succede se sono in ritardo?",
    a: "Una tolleranza di 10 minuti la diamo sempre. Oltre, riusciamo a tenerti la postazione solo se la coda lo permette — in caso contrario riprogrammiamo insieme uno slot nuovo.",
  },
  {
    q: "Posso prenotare per un'altra persona?",
    a: "Certo, basta inserire il nome e il telefono della persona che verrà al posto tuo nello step di conferma.",
  },
  {
    q: "Cosa porto con me al primo appuntamento?",
    a: "Niente, ti aspettiamo già con il rituale pronto. Se hai una foto di riferimento di un taglio o uno styling che ti piace, puoi mostrarcela direttamente sul telefono — aiuta tantissimo il barber a calibrare il lavoro.",
  },
];
---

<RootLayout
  title="Prenota online · Hair Rich Olbia"
  description="Prenota il tuo appuntamento da Hair Rich Olbia in meno di 30 secondi. Disponibilità in tempo reale, nessun pagamento richiesto online."
>
  <SiteHeader client:load />
  <main>
    <PageHero
      client:load
      eyebrow="Booking · Prenotazione online"
      titleA="Prenota in"
      titleB="trenta secondi"
      intro="Disponibilità in tempo reale, conferma immediata, nessun pagamento online. Scegli servizio, ora e barber — pensiamo noi al resto."
      bgImage="provvisorio/IMG_2493.jpeg"
      metaLeft="Slot live · 365 giorni"
      metaRight="04 / Prenota"
    />

    <BookingSection client:visible />

    <ProcessSteps
      client:idle
      eyebrow="Come funziona"
      title="Dal click alla postazione, senza attriti."
      steps={STEPS}
    />

    <ProcessSteps
      client:idle
      eyebrow="Politiche"
      title="Trasparenza prima del taglio."
      steps={POLICIES}
    />

    <FAQAccordion
      client:idle
      eyebrow="Domande frequenti"
      title="Tutto quello che devi sapere prima di venire."
      items={FAQ}
    />

    <Footer client:idle />
  </main>

  <ToastViewport client:load />
  <MobileBottomBar client:idle />
  <MobileMenu client:idle />
  <BookingDrawer client:idle />
</RootLayout>

---
import { useTranslations, getLangFromUrl } from "@/i18n";

interface Props {
  doc: "privacy" | "cookie" | "terms";
}

const { doc } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = lang === "it" ? "/" : `/${lang}/`;
const data = t.legal[doc];
---

<div class="min-h-screen bg-black pt-24 pb-20 px-6 font-body">
  <div class="max-w-3xl mx-auto space-y-8">
    <a
      href={homeHref}
      class="text-sm text-silver hover:text-warm-white transition-colors uppercase tracking-widest font-bold inline-block"
    >
      {t.legal.backHome}
    </a>
    <header>
      <span class="text-display-alt text-2xl text-accent-warm">{lang === "it" ? "Legal" : lang === "en" ? "Legal" : lang === "fr" ? "Légal" : "Rechtliches"}</span>
      <h1 class="text-display text-4xl md:text-5xl text-warm-white tracking-tight mt-1">
        {data.title}
      </h1>
      <p class="mt-3 text-silver-dark text-xs uppercase tracking-[0.3em] font-body font-semibold">
        {data.lastUpdate}
      </p>
    </header>

    <div class="space-y-6">
      {data.sections.map((s) => (
        <section>
          <h2 class="text-display text-xl md:text-2xl text-warm-white tracking-tight mb-3">
            {s.heading}
          </h2>
          <p class="text-warm-white-muted text-base leading-relaxed">{s.body}</p>
        </section>
      ))}
    </div>
  </div>
</div>

---
import { IntroSequence } from "./landing/IntroSequence";
import { HeroSection } from "./landing/HeroSection";
import { StatsBanner } from "./landing/StatsBanner";
import { ManifestoSection } from "./landing/ManifestoSection";
import { ServicesSection } from "./landing/ServicesSection";
import { WhyUsSection } from "./landing/WhyUsSection";
import { TeamSection } from "./landing/TeamSection";
import { GallerySection } from "./landing/GallerySection";
import { ReviewsSection } from "./landing/ReviewsSection";
import { Footer } from "./landing/Footer";
import { MarqueeStrip } from "./landing/_shared/MarqueeStrip";
import { SiteHeader } from "./ui/SiteHeader";
import { MobileBottomBar } from "./ui/MobileBottomBar";
import { MobileMenu } from "./ui/MobileMenu";
import { BookingDrawer } from "./booking/BookingDrawer";
import { ToastViewport } from "./ui/ToastViewport";
import { CookieBanner } from "./ui/CookieBanner";
import { InstallPrompt } from "./ui/InstallPrompt";
import type { Locale } from "@/i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// Marquee items lang-aware (passati come props ai componenti React).
// Le sezioni internamente leggono la lingua da `document.body.dataset.lang`
// via il custom hook `useLang()` (introdotto nella Wave 1.6).
const marqueeItems: Record<Locale, { headline: string[]; ribbon2: string[] }> = {
  it: {
    headline: ["TAGLIO", "Barba", "RITUALI", "Styling", "OLBIA", "Sardegna"],
    ribbon2: ["Book now", "Via Regina Elena 33/A", "0789 1891049", "@hair_rich_"],
  },
  en: {
    headline: ["CUT", "Beard", "RITUALS", "Styling", "OLBIA", "Sardinia"],
    ribbon2: ["Book now", "Via Regina Elena 33/A", "+39 0789 1891049", "@hair_rich_"],
  },
  fr: {
    headline: ["COUPE", "Barbe", "RITUELS", "Styling", "OLBIA", "Sardaigne"],
    ribbon2: ["Réservez", "Via Regina Elena 33/A", "+39 0789 1891049", "@hair_rich_"],
  },
  de: {
    headline: ["SCHNITT", "Bart", "RITUALE", "Styling", "OLBIA", "Sardinien"],
    ribbon2: ["Jetzt buchen", "Via Regina Elena 33/A", "+39 0789 1891049", "@hair_rich_"],
  },
};

const m = marqueeItems[lang];
---

<SiteHeader client:load />
<main>
  <IntroSequence client:load />
  <HeroSection client:load />
  <StatsBanner client:visible />

  <MarqueeStrip client:visible variant="headline" items={m.headline} />

  <ManifestoSection client:visible />
  <ServicesSection client:visible />
  <WhyUsSection client:visible />
  <TeamSection client:visible />
  <GallerySection client:visible />
  <ReviewsSection client:visible />

  <MarqueeStrip client:visible variant="ribbon" items={m.ribbon2} />

  <Footer client:visible />
</main>

<div data-intro-hidden style="display: contents">
  <CookieBanner client:idle />
  <InstallPrompt client:idle />
</div>
<MobileBottomBar client:idle />
<MobileMenu client:idle />
<BookingDrawer client:idle />
<ToastViewport client:load />

<script is:inline>
  // Skip intro flag setting if utente già vista l'intro (localStorage).
  // Altrimenti settiamo sincrono prima dell'hydration così gli island
  // idle non flashano dentro all'intro.
  try {
    if (localStorage.getItem("hr-intro-seen") === "1") {
      document.body.dataset.introActive = "false";
    } else {
      document.body.dataset.introActive = "true";
    }
  } catch {
    document.body.dataset.introActive = "true";
  }
</script>
